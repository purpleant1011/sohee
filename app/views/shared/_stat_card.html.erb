<%# P3-1 (2026-07-13): stat_card partial — 4-카드 요약용 %>
<% color = local_assigns[:color] || "slate"
   icon  = local_assigns[:icon] || "📊" %>
<div class="rounded-lg border border-slate-200 bg-white p-4">
  <div class="flex items-start justify-between mb-2">
    <span class="text-xs font-medium text-slate-500 uppercase tracking-wider"><%= local_assigns[:label] %></span>
    <span class="text-lg"><%= icon %></span>
  </div>
  <div class="text-2xl font-bold text-<%= color %>-700"><%= local_assigns[:value] %></div>
  <% if local_assigns[:hint].present? %>
    <p class="text-xs text-slate-400 mt-1"><%= local_assigns[:hint] %></p>
  <% end %>
</div>