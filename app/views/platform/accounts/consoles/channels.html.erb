<%# channels.html.erb — P4-3d: 채널 연결 + 통계 + sync/toggle/disconnect 액션 %>
<% content_for :title, "#{@account.name} · 채널 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto space-y-6">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "채널" %>

  <header>
    <h1 class="text-2xl font-bold text-slate-900">🔌 채널 연결 상태</h1>
    <p class="text-sm text-slate-500 mt-1">외부 채널(Discord, Instagram, Webhook 등) 연결과 테스트/공식 모드 전환을 관리합니다.</p>
  </header>

  <%# ── 5-stat ── %>
  <section class="grid grid-cols-2 md:grid-cols-5 gap-2">
    <% [
      ["전체",      @channel_stats[:total],    "slate"],
      ["Discord",   @channel_stats[:discord],  "indigo"],
      ["활성",      @channel_stats[:active],   "emerald"],
      ["테스트",    @channel_stats[:test],     "amber"],
      ["공식",      @channel_stats[:official], "blue"]
    ].each do |label, count, color| %>
      <div class="rounded-lg border border-<%= color %>-200 bg-<%= color %>-50 p-3 text-center">
        <div class="text-2xl font-bold text-<%= color %>-700"><%= count %></div>
        <div class="text-xs text-slate-600 mt-0.5"><%= label %></div>
      </div>
    <% end %>
  </section>

  <%# ── 채널 카드 (행별 액션) ── %>
  <% if @channel_connections.empty? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
      <div class="text-slate-400 text-5xl mb-3">🔌</div>
      <h3 class="text-base font-semibold text-slate-700">연결된 채널이 없습니다</h3>
      <p class="text-sm text-slate-500 mt-1">셋업에서 첫 채널을 연결하세요.</p>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @channel_connections.each do |cc| %>
        <div class="bg-white rounded-lg border border-slate-200 p-4">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">
                  <%= cc.kind %>
                </span>
                <% tm = cc.respond_to?(:scopes_json) && cc.scopes_json.is_a?(Hash) ? cc.scopes_json["test_mode"] : false %>
                <% if tm %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">테스트</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">공식</span>
                <% end %>
                <% st = cc.respond_to?(:status) ? cc.status.to_s : "active" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                  <%= st == 'active' || st == 'connected' ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-700' %>">
                  <%= st %>
                </span>
              </div>
              <h3 class="text-sm font-semibold text-slate-900">
                <%= cc.respond_to?(:display_name) && cc.display_name.present? ? cc.display_name :
                      (cc.respond_to?(:name) ? cc.name : "채널 ##{cc.id}") %>
              </h3>
              <% scopes = cc.respond_to?(:channel_scopes) ? cc.channel_scopes.pluck(:scope) : [] %>
              <% if scopes.any? %>
                <p class="text-xs text-slate-600 mt-1">스코프: <%= scopes.first(5).join(", ") %><%= scopes.size > 5 ? " +#{scopes.size - 5}" : "" %></p>
              <% end %>
              <p class="text-xs text-slate-500 mt-1">연결일: <%= cc.created_at&.strftime("%Y-%m-%d %H:%M") %></p>
            </div>

            <div class="flex flex-col gap-1.5 shrink-0">
              <%= button_to "🔄 동기화", platform_account_console_channel_sync_path(@account, cc.id),
                    method: :post, class: "px-3 py-1.5 rounded-md bg-sky-600 text-white text-xs font-medium hover:bg-sky-700" %>
              <%= button_to (cc.respond_to?(:scopes_json) && cc.scopes_json.is_a?(Hash) && cc.scopes_json["test_mode"] ? "🚀 공식으로" : "🧪 테스트로"),
                    platform_account_console_channel_toggle_path(@account, cc.id),
                    method: :post, class: "px-3 py-1.5 rounded-md bg-amber-100 text-amber-800 text-xs font-medium hover:bg-amber-200" %>
              <%= button_to "⛔ 연결 해제", platform_account_console_channel_disconnect_path(@account, cc.id),
                    method: :post, data: { confirm: "이 채널 연결을 해제할까요?" },
                    class: "px-3 py-1.5 rounded-md bg-rose-100 text-rose-700 text-xs font-medium hover:bg-rose-200" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :channels %>
</div>