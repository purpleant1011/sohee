<%# monitoring.html.erb — P4-3: AutomationExecution + PublicationAttempt 2개 큐 %>
<% content_for :title, "#{@account.name} · 자동 실행 모니터링 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "모니터링" %>

  <header class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">자동 실행 모니터링</h1>
    <p class="text-sm text-slate-500 mt-1">
      자동화 규칙 실행과 외부 채널 게시 시도를 시간순으로 보고합니다. 실패/지연 케이스를 빠르게 식별하세요.
    </p>
  </header>

  <%# ---- 자동 실행 ---- %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-slate-800 mb-3">
      자동화 실행
      <span class="ml-2 text-xs font-normal text-slate-500">(최근 50건)</span>
    </h2>
    <% if @automation_executions.blank? || @automation_executions.empty? %>
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">
        실행 이력이 없습니다.
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">시각</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">상태</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">시도</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">규칙</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">직원</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">에러</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-slate-200">
            <% @automation_executions.each do |ex| %>
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-2 text-xs text-slate-600 whitespace-nowrap">
                  <%= ex.created_at&.strftime("%m-%d %H:%M:%S") %>
                </td>
                <td class="px-4 py-2 text-xs">
                  <span class="inline-flex items-center px-2 py-0.5 rounded font-medium
                    <%= case ex.state.to_s
                        when /succeeded|completed/ then 'bg-emerald-100 text-emerald-800'
                        when /running|in_progress/ then 'bg-blue-100 text-blue-800'
                        when /failed/ then 'bg-rose-100 text-rose-800'
                        when /pending|scheduled|awaiting_approval/ then 'bg-amber-100 text-amber-800'
                        else 'bg-slate-100 text-slate-700'
                        end %>">
                    <%= ex.state %>
                  </span>
                </td>
                <td class="px-4 py-2 text-xs text-slate-600">
                  <%= ex.attempts %>/<%= ex.max_attempts %>
                </td>
                <td class="px-4 py-2 text-xs text-slate-700">
                  <%= ex.automation_rule_id %>
                </td>
                <td class="px-4 py-2 text-xs text-slate-600">
                  <%= ex.ai_employee_id || "—" %>
                </td>
                <td class="px-4 py-2 text-xs text-rose-700 font-mono truncate max-w-xs">
                  <%= ex.error_message.presence || "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>

  <%# ---- 게시 시도 ---- %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-slate-800 mb-3">
      채널 게시 시도
      <span class="ml-2 text-xs font-normal text-slate-500">(최근 50건)</span>
    </h2>
    <% if @publication_attempts.blank? || @publication_attempts.empty? %>
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">
        게시 이력이 없습니다.
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">시각</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">상태</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">시도</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">콘텐츠</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">채널</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">외부 URL</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-slate-200">
            <% @publication_attempts.each do |pa| %>
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-2 text-xs text-slate-600 whitespace-nowrap">
                  <%= pa.created_at&.strftime("%m-%d %H:%M:%S") %>
                </td>
                <td class="px-4 py-2 text-xs">
                  <span class="inline-flex items-center px-2 py-0.5 rounded font-medium
                    <%= case pa.state.to_s
                        when /succeeded|posted|published/ then 'bg-emerald-100 text-emerald-800'
                        when /failed/ then 'bg-rose-100 text-rose-800'
                        else 'bg-slate-100 text-slate-700'
                        end %>">
                    <%= pa.state %>
                  </span>
                </td>
                <td class="px-4 py-2 text-xs text-slate-600">
                  <%= pa.attempts %>
                </td>
                <td class="px-4 py-2 text-xs text-slate-700">
                  <%= pa.content_item_id %>
                </td>
                <td class="px-4 py-2 text-xs text-slate-600">
                  <%= pa.channel_connection_id %>
                </td>
                <td class="px-4 py-2 text-xs">
                  <% if pa.external_url.present? %>
                    <a href="<%= pa.external_url %>" target="_blank" rel="noopener"
                       class="text-blue-600 hover:underline truncate inline-block max-w-xs align-bottom">
                      <%= pa.external_url %>
                    </a>
                  <% else %>
                    <span class="text-slate-400">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :monitoring %>
</div>