<%# content.html.erb — P4-3d: 콘텐츠 캘린더 + 통계 + 필터 + 승인/거부/게시 액션 %>
<% content_for :title, "#{@account.name} · 콘텐츠 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto space-y-6">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "콘텐츠" %>

  <header class="flex items-baseline justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">📅 콘텐츠 캘린더</h1>
      <p class="text-sm text-slate-500 mt-1">AI 직원이 생성한 콘텐츠와 검수/게시 흐름을 한 눈에 봅니다.</p>
    </div>
    <div class="flex gap-2">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">총 <%= @content_stats[:total] %>건</span>
    </div>
  </header>

  <%# ── 6-stat row ── %>
  <section class="grid grid-cols-2 md:grid-cols-6 gap-2">
    <% [
      ["전체",     @content_stats[:total],     "all",       "slate"],
      ["초안",     @content_stats[:draft],     "draft",     "amber"],
      ["승인",     @content_stats[:approved],  "approved",  "blue"],
      ["예약",     @content_stats[:scheduled], "scheduled", "sky"],
      ["발행",     @content_stats[:published], "published", "emerald"],
      ["거부",     @content_stats[:failed],    "rejected",  "rose"]
    ].each do |label, count, key, color| %>
      <% is_current = (@content_filter == key) || (@content_filter == "all" && key == "all") %>
      <a href="<%= platform_account_console_content_path(@account, filter: key) %>"
         class="rounded-lg border p-3 text-center transition-colors <%= is_current ? "border-#{color}-400 bg-#{color}-50" : "border-slate-200 bg-white hover:bg-slate-50" %>">
        <div class="text-2xl font-bold text-<%= color %>-700"><%= count %></div>
        <div class="text-xs text-slate-600 mt-0.5"><%= label %></div>
      </a>
    <% end %>
  </section>

  <%# ── 콘텐츠 목록 (행별 액션) ── %>
  <% if @content_items.empty? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
      <div class="text-slate-400 text-5xl mb-3">📝</div>
      <h3 class="text-base font-semibold text-slate-700">콘텐츠가 없습니다</h3>
      <p class="text-sm text-slate-500 mt-1">이 필터에 해당하는 콘텐츠가 없거나, AI 직원이 아직 생성하지 않았습니다.</p>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @content_items.each do |item| %>
        <div class="bg-white rounded-lg border border-slate-200 p-4">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs text-slate-500 font-mono">#<%= item.id %></span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-700">
                  <%= item.respond_to?(:content_kind) ? item.content_kind : "—" %>
                </span>
                <% st = item.state.to_s %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                  <%= case st
                      when 'published' then 'bg-emerald-100 text-emerald-800'
                      when 'approved'  then 'bg-blue-100 text-blue-800'
                      when 'scheduled' then 'bg-sky-100 text-sky-800'
                      when 'draft'     then 'bg-amber-100 text-amber-800'
                      else 'bg-slate-100 text-slate-700'
                      end %>">
                  <%= st %>
                </span>
                <% if item.respond_to?(:safety_state) && item.safety_state.present? && item.safety_state != "passed" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-rose-100 text-rose-800">
                    안전: <%= item.safety_state %>
                  </span>
                <% end %>
              </div>
              <h3 class="text-sm font-semibold text-slate-900">
                <%= item.respond_to?(:title) && item.title.present? ? item.title : "(제목 없음)" %>
              </h3>
              <% if item.respond_to?(:body) && item.body.present? %>
                <p class="text-xs text-slate-600 mt-1 line-clamp-2"><%= item.body.to_s[0, 200] %></p>
              <% end %>
              <div class="mt-2 flex items-center gap-3 text-xs text-slate-500">
                <% if item.respond_to?(:scheduled_at) && item.scheduled_at %>
                  <span>📅 예약: <%= item.scheduled_at.strftime("%m-%d %H:%M") %></span>
                <% end %>
                <% if item.respond_to?(:published_at) && item.published_at %>
                  <span>✅ 발행: <%= item.published_at.strftime("%Y-%m-%d %H:%M") %></span>
                <% end %>
                <% if item.respond_to?(:published_external_url) && item.published_external_url.present? %>
                  <a href="<%= item.published_external_url %>" target="_blank" rel="noopener" class="text-blue-600 hover:underline">🔗 외부 링크</a>
                <% end %>
                <span>생성: <%= item.created_at&.strftime("%m-%d %H:%M") %></span>
              </div>
            </div>

            <%# ── 액션 버튼 ── %>
            <div class="flex flex-col gap-1.5 shrink-0">
              <% if item.state == "draft" || item.state == "approved" %>
                <% if item.state == "draft" %>
                  <%= button_to "✅ 승인", platform_account_console_content_approve_path(@account, item.id),
                        method: :post, class: "px-3 py-1.5 rounded-md bg-blue-600 text-white text-xs font-medium hover:bg-blue-700" %>
                <% end %>
                <% if item.state == "approved" %>
                  <%= button_to "🚀 게시", platform_account_console_content_publish_path(@account, item.id),
                        method: :post, class: "px-3 py-1.5 rounded-md bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700" %>
                <% end %>
                <%= button_to "❌ 거부", platform_account_console_content_reject_path(@account, item.id),
                      method: :post, class: "px-3 py-1.5 rounded-md bg-rose-100 text-rose-700 text-xs font-medium hover:bg-rose-200" %>
              <% else %>
                <span class="px-3 py-1.5 rounded-md bg-slate-50 text-slate-400 text-xs text-center">액션 없음</span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :content %>
</div>