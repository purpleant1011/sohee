<%# persona.html.erb — P4-3: AI 직원 목록 %>
<% content_for :title, "#{@account.name} · 페르소나 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "페르소나" %>

  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">페르소나 (AI 직원)</h1>
      <p class="text-sm text-slate-500 mt-1">
        이 사업자가 운영하는 AI 직원과 그 역할/지식/자동화 권한을 보여줍니다.
      </p>
    </div>
    <div class="text-sm text-slate-500">
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-700">
        <%= @ai_employees.size %>명
      </span>
    </div>
  </header>

  <% if @ai_employees.empty? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
      <div class="text-slate-400 text-5xl mb-3">👤</div>
      <h3 class="text-base font-semibold text-slate-700">AI 직원이 없습니다</h3>
      <p class="text-sm text-slate-500 mt-1">셋업에서 첫 AI 직원을 만들어 주세요.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% @ai_employees.each do |emp| %>
        <div class="bg-white rounded-lg border border-slate-200 p-4">
          <div class="flex items-start justify-between">
            <div>
              <div class="text-xs text-slate-500 font-mono">#<%= emp.id %></div>
              <h3 class="text-base font-semibold text-slate-900 mt-0.5">
                <%= emp.name %>
              </h3>
              <% if emp.respond_to?(:role) && emp.role.present? %>
                <p class="text-xs text-slate-600 mt-1"><%= emp.role %></p>
              <% end %>
            </div>
            <% if emp.respond_to?(:status) %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                <%= emp.status.to_s == 'active' ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-700' %>">
                <%= emp.status %>
              </span>
            <% end %>
          </div>
          <% if emp.respond_to?(:description) && emp.description.present? %>
            <p class="text-xs text-slate-600 mt-3 line-clamp-3"><%= emp.description %></p>
          <% end %>
          <div class="mt-3 pt-3 border-t border-slate-100 text-xs text-slate-500 flex items-center justify-between">
            <span>생성: <%= emp.created_at&.strftime("%Y-%m-%d") %></span>
            <% if emp.respond_to?(:staff_code) && emp.staff_code.present? %>
              <span class="font-mono"><%= emp.staff_code %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :persona %>
</div>