<%# runtime.html.erb — P4-3d: Runtime 설정 + 하트비트 + 통계 + 액션 %>
<% rc = @runtime_configs || [] %>
<% hb = @runtime_heartbeats || [] %>
<% active_rc = rc.respond_to?(:where) ? rc.where(status: "active") : [] %>
<% hb_ok = hb.respond_to?(:where) ? hb.where(status: "ok").count : 0 %>
<% hb_err = hb.respond_to?(:where) ? hb.where("status LIKE ?", "%error%").count : 0 %>
<div class="px-6 py-8 max-w-6xl mx-auto space-y-6">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "Runtime" %>

  <header>
    <h1 class="text-2xl font-bold text-slate-900">⚙️ Runtime 설정 / 헬스체크</h1>
    <p class="text-sm text-slate-500 mt-1">AI 직원이 사용하는 모델/프롬프트 설정과 헬스체크 결과.</p>
  </header>

  <%# ── 3-통계 ── %>
  <section class="grid grid-cols-3 gap-2">
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-center">
      <div class="text-2xl font-bold text-emerald-700"><%= active_rc.size %></div>
      <div class="text-xs text-slate-600 mt-0.5">활성 버전</div>
    </div>
    <div class="rounded-lg border border-blue-200 bg-blue-50 p-3 text-center">
      <div class="text-2xl font-bold text-blue-700"><%= hb_ok %></div>
      <div class="text-xs text-slate-600 mt-0.5">헬스 OK</div>
    </div>
    <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-center">
      <div class="text-2xl font-bold text-rose-700"><%= hb_err %></div>
      <div class="text-xs text-slate-600 mt-0.5">헬스 오류</div>
    </div>
  </section>

  <%# ── Runtime Configs ── %>
  <section>
    <h2 class="text-base font-bold text-slate-900 mb-3">Runtime Config (<%= rc.size %>개)</h2>
    <% if rc.empty? %>
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">등록된 Runtime Config가 없습니다.</div>
    <% else %>
      <div class="space-y-2">
        <% rc.first(20).each do |cfg| %>
          <div class="bg-white rounded-lg border border-slate-200 p-3">
            <div class="flex items-center gap-2 mb-1">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono bg-slate-100 text-slate-700">v<%= cfg.version %></span>
              <% if cfg.respond_to?(:status) && cfg.status == "active" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 text-emerald-800">활성</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-700">대기</span>
              <% end %>
              <% if cfg.respond_to?(:model) && cfg.model.present? %>
                <span class="text-xs text-slate-600 font-mono"><%= cfg.model %></span>
              <% end %>
              <span class="text-xs text-slate-500 ml-auto"><%= cfg.created_at&.strftime("%Y-%m-%d %H:%M") %></span>
            </div>
            <% if cfg.respond_to?(:meta_json) && cfg.meta_json.present? %>
              <p class="text-xs text-slate-600 mt-1"><%= JSON.dump(cfg.meta_json)[0,200] %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <%# ── Heartbeats ── %>
  <section>
    <h2 class="text-base font-bold text-slate-900 mb-3">헬스체크 (<%= hb.size %>건)</h2>
    <% if hb.empty? %>
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">헬스체크 이력이 없습니다.</div>
    <% else %>
      <div class="space-y-2">
        <% hb.first(20).each do |h| %>
          <div class="bg-white rounded-lg border border-slate-200 p-3">
            <div class="flex items-center gap-2">
              <span class="text-xs text-slate-500 font-mono"><%= h.checked_at&.strftime("%m-%d %H:%M:%S") %></span>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                <%= case h.status.to_s
                    when 'ok', 'healthy' then 'bg-emerald-100 text-emerald-800'
                    when 'degraded', 'warning' then 'bg-amber-100 text-amber-800'
                    when 'down', 'unhealthy', 'error' then 'bg-rose-100 text-rose-800'
                    else 'bg-slate-100 text-slate-700'
                    end %>">
                <%= h.status %>
              </span>
              <span class="text-xs text-slate-500">소스: <%= h.source %></span>
              <% if h.respond_to?(:open_jobs) %>
                <span class="text-xs text-slate-500">열린 작업: <%= h.open_jobs %></span>
              <% end %>
              <% if h.respond_to?(:failed_jobs_24h) %>
                <span class="text-xs text-slate-500">24h 실패: <%= h.failed_jobs_24h %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :runtime %>
</div>