<%# safety.html.erb — P4-3d: 안전 검열 + pass/warn/block 통계 + 액션 %>
<% logs = @safety_logs || [] %>
<% passed = logs.respond_to?(:where) ? logs.where(verdict: "pass").count : 0 %>
<% warned = logs.respond_to?(:where) ? logs.where(verdict: "warn").count : 0 %>
<% blocked = logs.respond_to?(:where) ? logs.where(verdict: "block").count : 0 rescue 0 %>
<div class="px-6 py-8 max-w-6xl mx-auto space-y-6">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "안전" %>

  <header>
    <h1 class="text-2xl font-bold text-slate-900">🛡️ 안전 검열 로그</h1>
    <p class="text-sm text-slate-500 mt-1">AI 직원이 생성한 콘텐츠가 안전 규칙을 통과한 기록입니다.</p>
  </header>

  <%# ── 3-통계 ── %>
  <section class="grid grid-cols-3 gap-2">
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-center">
      <div class="text-2xl font-bold text-emerald-700"><%= passed %></div>
      <div class="text-xs text-emerald-700 uppercase mt-0.5">통과</div>
    </div>
    <div class="rounded-lg border border-amber-200 bg-amber-50 p-3 text-center">
      <div class="text-2xl font-bold text-amber-700"><%= warned %></div>
      <div class="text-xs text-amber-700 uppercase mt-0.5">경고</div>
    </div>
    <div class="rounded-lg border border-rose-200 bg-rose-50 p-3 text-center">
      <div class="text-2xl font-bold text-rose-700"><%= blocked %></div>
      <div class="text-xs text-rose-700 uppercase mt-0.5">차단</div>
    </div>
  </section>

  <%# ── 통과율 ── %>
  <% total = passed + warned + blocked %>
  <% if total > 0 %>
    <% pass_pct = (passed * 100 / total) %>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-semibold text-slate-900">전체 통과율</h3>
        <span class="text-sm font-bold text-emerald-700"><%= pass_pct %>%</span>
      </div>
      <div class="h-2 bg-slate-100 rounded-full overflow-hidden flex">
        <div class="bg-emerald-500" style="width: <%= passed * 100 / total %>%"></div>
        <div class="bg-amber-500" style="width: <%= warned * 100 / total %>%"></div>
        <div class="bg-rose-500" style="width: <%= blocked * 100 / total %>%"></div>
      </div>
    </div>
  <% end %>

  <%# ── 로그 ── %>
  <section>
    <h2 class="text-base font-bold text-slate-900 mb-3">검열 이력 (최근 50건)</h2>
    <% if logs.empty? %>
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
        <div class="text-slate-400 text-5xl mb-3">🛡️</div>
        <h3 class="text-base font-semibold text-slate-700">안전 검열 기록이 없습니다</h3>
      </div>
    <% else %>
      <div class="space-y-2">
        <% logs.first(50).each do |log| %>
          <div class="bg-white rounded-lg border border-slate-200 p-3">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-slate-500 font-mono">#<%= log.id %></span>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                <%= case log.verdict.to_s
                    when 'pass' then 'bg-emerald-100 text-emerald-800'
                    when 'warn' then 'bg-amber-100 text-amber-800'
                    when 'block' then 'bg-rose-100 text-rose-800'
                    else 'bg-slate-100 text-slate-700'
                    end %>">
                <%= log.verdict %>
              </span>
              <span class="text-xs text-slate-500">단계: <%= log.stage %></span>
              <span class="text-xs text-slate-500 ml-auto"><%= log.created_at&.strftime("%m-%d %H:%M:%S") %></span>
            </div>
            <% if log.rules_json.present? %>
              <p class="text-xs text-slate-700 mt-1">
                규칙: <%= log.rules_json.is_a?(Array) ? log.rules_json.join(", ") : log.rules_json.to_s %>
              </p>
            <% end %>
            <% if log.notes.present? %>
              <p class="text-xs text-slate-600 mt-1"><%= log.notes %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :safety %>
</div>