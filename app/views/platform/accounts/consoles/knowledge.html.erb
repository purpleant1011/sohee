<%# knowledge.html.erb — P4-3d: 매장 안내 자료 + FAQ + 통계 + 탭 %>
<% content_for :title, "#{@account.name} · 지식 · 운영 콘솔" %>
<% docs = @knowledge_documents || [] %>
<% faqs = @faqs || [] %>
<% doc_count = docs.respond_to?(:size) ? docs.size : 0 %>
<% faq_count = faqs.respond_to?(:size) ? faqs.size : 0 %>
<div class="px-6 py-8 max-w-6xl mx-auto space-y-6">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "매장 안내 자료" %>

  <header>
    <h1 class="text-2xl font-bold text-slate-900">📚 매장 안내 자료 / FAQ</h1>
    <p class="text-sm text-slate-500 mt-1">AI 직원이 인용하는 RAG 소스를 관리합니다.</p>
  </header>

  <%# ── 2-통계 ── %>
  <section class="grid grid-cols-2 gap-2">
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-center">
      <div class="text-2xl font-bold text-emerald-700"><%= doc_count %></div>
      <div class="text-xs text-slate-600 mt-0.5">문서</div>
    </div>
    <div class="rounded-lg border border-blue-200 bg-blue-50 p-3 text-center">
      <div class="text-2xl font-bold text-blue-700"><%= faq_count %></div>
      <div class="text-xs text-slate-600 mt-0.5">FAQ</div>
    </div>
  </section>

  <%# ── 문서 ── %>
  <section>
    <h2 class="text-base font-bold text-slate-900 mb-3">매장 안내 자료 (<%= doc_count %>건)</h2>
    <% if doc_count.zero? %>
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">등록된 문서가 없습니다.</div>
    <% else %>
      <div class="space-y-2">
        <% docs.first(20).each do |doc| %>
          <div class="bg-white rounded-lg border border-slate-200 p-3">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="text-xs text-slate-500 font-mono">#<%= doc.id %></div>
                <h3 class="text-sm font-semibold text-slate-900 mt-0.5">
                  <%= doc.respond_to?(:title) ? doc.title : (doc.respond_to?(:name) ? doc.name : "문서") %>
                </h3>
                <% if doc.respond_to?(:body) && doc.body.present? %>
                  <p class="text-xs text-slate-600 mt-1 line-clamp-2"><%= doc.body.to_s[0, 200] %></p>
                <% end %>
                <div class="text-xs text-slate-500 mt-2">등록: <%= doc.created_at&.strftime("%Y-%m-%d") %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <%# ── FAQ ── %>
  <section>
    <h2 class="text-base font-bold text-slate-900 mb-3">FAQ (<%= faq_count %>건)</h2>
    <% if faq_count.zero? %>
      <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">등록된 FAQ가 없습니다.</div>
    <% else %>
      <div class="space-y-2">
        <% faqs.first(20).each do |faq| %>
          <div class="bg-white rounded-lg border border-slate-200 p-3">
            <div class="flex items-start gap-2">
              <span class="text-emerald-600 font-bold text-sm">Q.</span>
              <div class="flex-1">
                <h3 class="text-sm font-medium text-slate-900"><%= faq.respond_to?(:question) ? faq.question : "—" %></h3>
                <% if faq.respond_to?(:answer) && faq.answer.present? %>
                  <p class="text-xs text-slate-600 mt-1">A. <%= faq.answer.to_s[0, 200] %></p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :knowledge %>
</div>