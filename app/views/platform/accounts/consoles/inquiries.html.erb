<%# inquiries.html.erb — P4-3: Account 직접 inquiries 컬럼 부재 → BusinessProfile 경유 %>
<% content_for :title, "#{@account.name} · 문의함 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "문의함" %>

  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">문의함</h1>
      <p class="text-sm text-slate-500 mt-1">
        고객 문의를 시간순으로 보고, 답변 상태·담당 직원을 추적합니다.
        <%= @inquiries.respond_to?(:total_count) ? "(전체 #{@inquiries.total_count}건)" : "" %>
      </p>
    </div>
    <div class="text-sm text-slate-500">
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-700">
        <%= @account.name %>
      </span>
    </div>
  </header>

  <% if @inquiries.blank? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
      <div class="text-slate-400 text-5xl mb-3">💬</div>
      <h3 class="text-base font-semibold text-slate-700">아직 수신된 문의가 없습니다</h3>
      <p class="text-sm text-slate-500 mt-1">
        채널이 연결되고 첫 문의가 들어오면 이곳에 표시됩니다.
      </p>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">시각</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">채널</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">작성자</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">내용</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">상태</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">담당</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-200">
          <% @inquiries.each do |inq| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-2 text-xs text-slate-600 whitespace-nowrap">
                <%= inq.created_at&.strftime("%m-%d %H:%M") %>
              </td>
              <td class="px-4 py-2 text-xs text-slate-600">
                <%= inq.respond_to?(:channel) ? inq.channel : (inq.respond_to?(:channel_kind) ? inq.channel_kind : "—") %>
              </td>
              <td class="px-4 py-2 text-xs text-slate-700">
                <%= inq.respond_to?(:author_name) ? inq.author_name : (inq.respond_to?(:user_name) ? inq.user_name : "익명") %>
              </td>
              <td class="px-4 py-2 text-sm text-slate-900 max-w-md">
                <div class="truncate">
                  <%= inq.respond_to?(:body) ? inq.body : (inq.respond_to?(:content) ? inq.content : inq.attributes.to_s) %>
                </div>
              </td>
              <td class="px-4 py-2 text-xs">
                <% st = inq.respond_to?(:status) ? inq.status : "open" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded font-medium
                  <%= case st.to_s
                      when /pending|open|received/ then 'bg-amber-100 text-amber-800'
                      when /answered|replied|closed/ then 'bg-emerald-100 text-emerald-800'
                      else 'bg-slate-100 text-slate-700'
                      end %>">
                  <%= st %>
                </span>
              </td>
              <td class="px-4 py-2 text-xs text-slate-600">
                <%= inq.respond_to?(:assigned_ai_employee) && inq.assigned_ai_employee ? inq.assigned_ai_employee.name : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :inquiries %>
</div>