<%# audit.html.erb — P4-3: AuditEvent.account_id 직접 매칭, 100개 limit %>
<% content_for :title, "#{@account.name} · 감사 로그 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "감사 로그" %>

  <header class="mb-6 flex items-baseline justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">감사 로그</h1>
      <p class="text-sm text-slate-500 mt-1">
        운영자/사장/AI 직원의 모든 행동을 시간 역순으로 표시합니다. 최근 100건.
      </p>
    </div>
    <div class="text-sm text-slate-500">
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-700">
        <%= @account.name %>
      </span>
    </div>
  </header>

  <% if @audit_events.empty? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
      <div class="text-slate-400 text-5xl mb-3">📜</div>
      <h3 class="text-base font-semibold text-slate-700">감사 로그가 없습니다</h3>
      <p class="text-sm text-slate-500 mt-1">아직 기록된 활동이 없습니다.</p>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">시각</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">주체</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">액션</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">대상</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">메타</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-200">
          <% @audit_events.each do |evt| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-2 text-xs text-slate-600 whitespace-nowrap">
                <%= evt.occurred_at&.strftime("%Y-%m-%d %H:%M:%S") %>
              </td>
              <td class="px-4 py-2 text-xs">
                <span class="inline-flex items-center px-2 py-0.5 rounded font-medium bg-slate-100 text-slate-700">
                  <%= evt.actor_label.presence || evt.actor_kind.presence || "system" %>
                </span>
              </td>
              <td class="px-4 py-2 text-xs font-mono text-slate-800">
                <%= evt.action %>
              </td>
              <td class="px-4 py-2 text-xs text-slate-600">
                <% if evt.resource_type %>
                  <span class="text-slate-700"><%= evt.resource_type %></span>
                  <span class="text-slate-400">#<%= evt.resource_id %></span>
                <% else %>
                  <span class="text-slate-400">—</span>
                <% end %>
              </td>
              <td class="px-4 py-2 text-xs text-slate-500 font-mono truncate max-w-xs">
                <%= evt.metadata.present? ? JSON.dump(evt.metadata)[0,80] : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :audit %>
</div>