<%# automations.html.erb — P4-3: 자동화 규칙 + 최근 실행/승인 만료 카운트 %>
<% content_for :title, "#{@account.name} · 자동화 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "자동화" %>

  <header class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">자동화 규칙</h1>
    <p class="text-sm text-slate-500 mt-1">
      AI 직원이 자동으로 수행하는 게시/응답/리포트 규칙과 그 실행 상태를 보여줍니다.
    </p>
  </header>

  <% if @automation_rules.empty? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
      <div class="text-slate-400 text-5xl mb-3">⚙️</div>
      <h3 class="text-base font-semibold text-slate-700">자동화 규칙이 없습니다</h3>
      <p class="text-sm text-slate-500 mt-1">셋업에서 자동 게시/응답 규칙을 추가하세요.</p>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">ID</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">이름</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">상태</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">최근 실행</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">실행 횟수</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-200">
          <% @automation_rules.each do |rule| %>
            <% last = rule.automation_executions.order(created_at: :desc).first %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-2 text-xs text-slate-600 font-mono">#<%= rule.id %></td>
              <td class="px-4 py-2 text-sm text-slate-900">
                <%= rule.respond_to?(:name) ? rule.name : (rule.respond_to?(:title) ? rule.title : "—") %>
              </td>
              <td class="px-4 py-2 text-xs">
                <% st = rule.respond_to?(:status) ? rule.status : "active" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded font-medium
                  <%= case st.to_s
                      when 'active', 'enabled' then 'bg-emerald-100 text-emerald-800'
                      when 'paused' then 'bg-amber-100 text-amber-800'
                      else 'bg-slate-100 text-slate-700'
                      end %>">
                  <%= st %>
                </span>
              </td>
              <td class="px-4 py-2 text-xs text-slate-600">
                <% if last %>
                  <%= last.created_at&.strftime("%m-%d %H:%M") %>
                  <span class="ml-1 text-slate-400">(<%= last.state %>)</span>
                <% else %>
                  <span class="text-slate-400">없음</span>
                <% end %>
              </td>
              <td class="px-4 py-2 text-xs text-slate-600">
                <%= rule.automation_executions.size %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :automations %>
</div>