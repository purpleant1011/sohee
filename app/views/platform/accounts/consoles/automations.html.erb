<%# automations.html.erb — P4-3d: 자동화 규칙 + 통계 + toggle/run 액션 %>
<% content_for :title, "#{@account.name} · 자동화 · 운영 콘솔" %>
<div class="px-6 py-8 max-w-6xl mx-auto space-y-6">
  <%= render partial: "platform/accounts/consoles/breadcrumb", current: "자동화" %>

  <header>
    <h1 class="text-2xl font-bold text-slate-900">🤖 자동 게시 규칙</h1>
    <p class="text-sm text-slate-500 mt-1">AI 직원이 자동으로 수행하는 게시/응답/리포트 규칙과 그 실행 상태를 관리합니다.</p>
  </header>

  <%# ── 4-stat ── %>
  <section class="grid grid-cols-2 md:grid-cols-4 gap-2">
    <% [
      ["전체 규칙", @automation_stats[:total],  "slate"],
      ["활성",      @automation_stats[:active], "emerald"],
      ["일시중지",  @automation_stats[:paused], "amber"],
      ["24h 실행",  @automation_stats[:ran_24h], "blue"]
    ].each do |label, count, color| %>
      <div class="rounded-lg border border-<%= color %>-200 bg-<%= color %>-50 p-3 text-center">
        <div class="text-2xl font-bold text-<%= color %>-700"><%= count %></div>
        <div class="text-xs text-slate-600 mt-0.5"><%= label %></div>
      </div>
    <% end %>
  </section>

  <%# ── 규칙 카드 (행별 액션) ── %>
  <% if @automation_rules.empty? %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-12 text-center">
      <div class="text-slate-400 text-5xl mb-3">⚙️</div>
      <h3 class="text-base font-semibold text-slate-700">자동화 규칙이 없습니다</h3>
      <p class="text-sm text-slate-500 mt-1">셋업에서 자동 게시/응답 규칙을 추가하세요.</p>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @automation_rules.each do |rule| %>
        <% last = rule.automation_executions.order(created_at: :desc).first %>
        <% total_runs = rule.automation_executions.size %>
        <% success_runs = rule.automation_executions.where("state LIKE ?", "%success%").count %>
        <% success_pct = total_runs > 0 ? (success_runs * 100 / total_runs) : 0 %>
        <div class="bg-white rounded-lg border border-slate-200 p-4">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs text-slate-500 font-mono">#<%= rule.id %></span>
                <% st = rule.respond_to?(:status) ? rule.status.to_s : "active" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                  <%= case st
                      when 'active', 'enabled'  then 'bg-emerald-100 text-emerald-800'
                      when 'paused', 'disabled' then 'bg-amber-100 text-amber-800'
                      else 'bg-slate-100 text-slate-700'
                      end %>">
                  <%= st %>
                </span>
              </div>
              <h3 class="text-sm font-semibold text-slate-900">
                <%= rule.respond_to?(:name) ? rule.name : (rule.respond_to?(:title) ? rule.title : "규칙 ##{rule.id}") %>
              </h3>
              <% if rule.respond_to?(:description) && rule.description.present? %>
                <p class="text-xs text-slate-600 mt-1"><%= rule.description.to_s[0, 200] %></p>
              <% end %>
              <div class="mt-2 flex items-center gap-3 text-xs text-slate-500 flex-wrap">
                <span>실행 <%= total_runs %>회 · 성공률 <%= success_pct %>%</span>
                <% if last %>
                  <span>최근: <%= last.created_at&.strftime("%m-%d %H:%M") %> · <%= last.state %></span>
                <% else %>
                  <span>실행 이력 없음</span>
                <% end %>
              </div>
            </div>

            <div class="flex flex-col gap-1.5 shrink-0">
              <%= button_to (st == "active" ? "⏸ 일시중지" : "▶ 재개"),
                    platform_account_console_automation_toggle_path(@account, rule.id),
                    method: :post,
                    class: "px-3 py-1.5 rounded-md #{st == 'active' ? 'bg-amber-100 text-amber-800 hover:bg-amber-200' : 'bg-emerald-100 text-emerald-800 hover:bg-emerald-200'} text-xs font-medium" %>
              <%= button_to "⚡ 수동 실행", platform_account_console_automation_run_path(@account, rule.id),
                    method: :post, class: "px-3 py-1.5 rounded-md bg-blue-600 text-white text-xs font-medium hover:bg-blue-700" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= render partial: "platform/accounts/consoles/sibling_nav", current: :automations %>
</div>