<% content_for(:title, @source.title) %>
<header class="mb-6 flex justify-between items-start">
  <div>
    <h1 class="text-2xl font-bold"><%= @source.title %></h1>
    <p class="mt-1 text-sm text-slate-500">
      <span class="rounded bg-slate-100 px-2 py-0.5 text-xs"><%= @source.kind %></span>
      · AI 직원 <%= @source.ai_employee&.name || "공통" %>
      · 언어 <%= @source.language || "-" %>
      · 상태
      <% case @source.status
         when "ready" %><span class="text-emerald-700 font-medium">✓ 완료</span>
      <% when "processing", "pending" %><span class="text-amber-700 font-medium">⏳ 처리 중</span>
      <% when "failed" %><span class="text-rose-700 font-medium">✗ 실패</span>
      <% else %><%= @source.status %>
      <% end %>
    </p>
  </div>
  <div class="flex gap-2">
    <%= link_to "수정", "/app/knowledge/sources/#{@source.id}/edit", class: "inline-flex items-center rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    <%= button_to "재처리", "/app/knowledge/sources/#{@source.id}/sync", method: :post, class: "inline-flex items-center rounded-md border border-emerald-300 px-3 py-1.5 text-sm font-medium text-emerald-700 hover:bg-emerald-50" %>
    <%= button_to "삭제", "/app/knowledge/sources/#{@source.id}", method: :delete, data: { turbo_confirm: "정말 삭제하시겠습니까?" }, class: "inline-flex items-center rounded-md border border-rose-300 px-3 py-1.5 text-sm font-medium text-rose-700 hover:bg-rose-50" %>
  </div>
</header>

<% if @source.error_message.present? %>
  <div class="rounded-md border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700 mb-4">
    <strong>처리 실패:</strong> <%= @source.error_message %>
    <%= button_to "실패 처리 확정", app_knowledge_source_mark_failed_path(@source), method: :post, class: "ml-3 inline-flex items-center text-xs text-rose-700 underline" %>
  </div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <div class="rounded-md border border-slate-200 bg-white p-5">
    <h3 class="font-semibold mb-3">📎 첨부 파일</h3>
    <% if @source.file.attached? %>
      <p class="text-sm"><%= @source.file.filename %></p>
      <p class="text-xs text-slate-500 mt-1"><%= number_to_human_size(@source.file.byte_size) %> · <%= @source.file.content_type %></p>
      <% if @source.file.content_type.to_s.start_with?("image/") %>
        <div class="mt-3"><%= image_tag rails_blob_url(@source.file), class: "max-w-full rounded" %></div>
      <% end %>
    <% else %>
      <p class="text-xs text-slate-500">파일 첨부 없음</p>
    <% end %>
  </div>
  <div class="rounded-md border border-slate-200 bg-white p-5">
    <h3 class="font-semibold mb-3">🔖 태그</h3>
    <div class="flex flex-wrap gap-1.5">
      <% Array(@source.tags_json).each do |t| %><span class="rounded bg-indigo-100 px-2 py-0.5 text-xs text-indigo-700"><%= t %></span><% end %>
      <% if Array(@source.tags_json).empty? %><span class="text-xs text-slate-400">없음</span><% end %>
    </div>
    <% if @source.url.present? %>
      <p class="mt-4 text-xs"><strong>URL:</strong> <%= link_to @source.url, @source.url, target: "_blank", class: "text-indigo-600 hover:underline break-all" %></p>
    <% end %>
  </div>
</div>

<div class="rounded-md border border-slate-200 bg-white p-5">
  <h3 class="font-semibold mb-3">📑 처리된 청크 (<%= @documents.size %>)</h3>
  <% if @documents.any? %>
    <ul class="divide-y divide-slate-100 text-sm">
      <% @documents.each do |d| %>
        <li class="py-2">
          <span class="font-mono text-xs">#<%= d.id %></span>
          · <%= d.normalized_text&.truncate(80) || d.raw_text&.truncate(80) || "(빈 청크)" %>
          <span class="text-xs text-slate-500 ml-2"><%= d.created_at.strftime("%Y-%m-%d %H:%M") %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-500">아직 처리된 청크가 없습니다. 재처리를 시도해보세요.</p>
  <% end %>
</div>