<% content_for :title, "수정 제안 · 소희" %>

<%= render "shared/page_header", title: "📝 수정 제안 (ChangeProposal)", subtitle: "원장님이 Discord 에서 보내신 '이렇게 바꿔' 요청을 검토하고 승인 / 거부합니다." %>

<section class="mb-8">
  <h2 class="text-lg font-semibold text-slate-700 mb-3">⏳ 대기 중 (<%= @pending.size %>건)</h2>
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 divide-y divide-slate-100">
    <% if @pending.empty? %>
      <%= render "shared/empty_state", icon: "✅", title: "대기 중인 제안이 없습니다", description: "모든 제안이 처리되었습니다." %>
    <% else %>
      <% @pending.each do |p| %>
        <div class="p-4 flex items-center justify-between hover:bg-slate-50">
          <div>
            <div class="text-xs text-slate-500 mb-1">
              <code class="px-1.5 py-0.5 bg-slate-100 rounded text-slate-700"><%= p.target_kind %>.<%= p.target_field %></code>
              · <%= time_ago_in_words(p.created_at) %> 전
              · 만료: <%= p.expires_at&.strftime("%m/%d %H:%M") %>
            </div>
            <div class="text-sm text-slate-800"><%= p.display_summary %></div>
          </div>
          <%= link_to "검토 →", app_change_proposal_path(p), class: "px-3 py-1.5 text-sm bg-blue-600 text-white rounded-md hover:bg-blue-700" %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>

<section>
  <h2 class="text-lg font-semibold text-slate-700 mb-3">📚 최근 결정 (<%= @decided.size %>건)</h2>
  <div class="bg-white rounded-lg shadow-sm border border-slate-200 divide-y divide-slate-100">
    <% if @decided.empty? %>
      <%= render "shared/empty_state", icon: "📜", title: "결정 이력이 없습니다" %>
    <% else %>
      <% @decided.each do |p| %>
        <div class="p-4 hover:bg-slate-50">
          <div class="flex items-center gap-2 text-xs text-slate-500 mb-1">
            <span><%= p.decided_at&.strftime("%Y-%m-%d %H:%M") %></span>
            <% badge_class = case p.status
               when "approved" then "bg-green-100 text-green-700"
               when "rejected" then "bg-red-100 text-red-700"
               when "applied"  then "bg-blue-100 text-blue-700"
               else "bg-slate-100 text-slate-600" end %>
            <span class="px-2 py-0.5 rounded-full <%= badge_class %>"><%= p.status %></span>
          </div>
          <div class="text-sm text-slate-800"><%= p.display_summary %></div>
        </div>
      <% end %>
    <% end %>
  </div>
</section>