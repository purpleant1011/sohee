<% content_for :title, "메시지 동기화 · 소희" %>

<%= render "shared/page_header", title: "🔄 메시지 동기화 (Hermes ACK)", subtitle: "Discord 와 우리 DB 사이의 메시지 동기화 상태를 확인합니다." %>

<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <div class="bg-white rounded-lg p-4 shadow-sm border border-slate-200">
    <div class="text-xs text-slate-500">전체 메시지</div>
    <div class="text-xl font-semibold"><%= @total_events %></div>
  </div>
  <div class="bg-white rounded-lg p-4 shadow-sm border border-slate-200">
    <div class="text-xs text-slate-500">처리 완료</div>
    <div class="text-xl font-semibold text-green-600"><%= @processed %></div>
  </div>
  <div class="bg-white rounded-lg p-4 shadow-sm border border-slate-200">
    <div class="text-xs text-slate-500">처리 대기</div>
    <div class="text-xl font-semibold text-amber-600"><%= @pending %></div>
  </div>
  <div class="bg-white rounded-lg p-4 shadow-sm border border-slate-200">
    <div class="text-xs text-slate-500">에러</div>
    <div class="text-xl font-semibold text-red-600"><%= @errored %></div>
  </div>
</div>

<% if @errored > 0 %>
  <section>
    <h2 class="text-lg font-semibold text-slate-700 mb-3">🚨 최근 에러 (<%= @recent_errors.size %>건)</h2>
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 divide-y divide-slate-100">
      <% @recent_errors.each do |e| %>
        <div class="p-4 hover:bg-slate-50">
          <div class="flex items-center gap-2 text-xs text-slate-500 mb-1">
            <span>📨 <%= e.created_at.strftime("%Y-%m-%d %H:%M") %></span>
            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-600"><%= e.kind %></span>
          </div>
          <div class="text-sm text-red-700 font-mono"><%= e.processing_error.to_s.truncate(280) %></div>
          <div class="text-xs text-slate-500 mt-1">snowflake: <code><%= e.snowflake_id %></code></div>
        </div>
      <% end %>
    </div>
  </section>
<% else %>
  <%= render "shared/empty_state", icon: "✨", title: "모든 메시지가 정상 처리되었습니다", description: "Discord ↔ DB 동기화 상태가 깨끗합니다." %>
<% end %>