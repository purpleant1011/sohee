<% content_for :title, "자동 게시 규칙 · 소희 프로젝트" %>
<%
  intent_labels = {
    "post"        => "자동 게시",
    "report"      => "보고서",
    "reply"       => "자동 응답",
    "faq_update"  => "FAQ 업데이트",
    "data_export" => "데이터 백업"
  }
  status_color = {
    "active" => "bg-emerald-100 text-emerald-700",
    "draft"  => "bg-amber-100 text-amber-700",
    "paused" => "bg-rose-100 text-rose-700"
  }
  status_label = { "active" => "운영 중", "draft" => "승인 대기", "paused" => "일시중지" }
%>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">자동 게시 규칙</h1>
  <p class="text-xs text-slate-500 mt-1">소희가 자동으로 실행하는 게시·응답·보고 작업의 목록입니다. test/official 분리는 운영팀이 관리합니다.</p>
</div>

<%# 4-카드 요약 (§20 10초 안에) %>
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <%= render "shared/stat_card", label: "운영 중", value: @counts[:active], color: "emerald", icon: "✅" %>
  <%= render "shared/stat_card", label: "승인 대기", value: @counts[:pending], color: "amber", icon: "⏳" %>
  <%= render "shared/stat_card", label: "초안", value: @counts[:draft], color: "slate", icon: "📝" %>
  <%= render "shared/stat_card", label: "일시중지", value: @counts[:paused], color: "rose", icon: "⏸" %>
</div>

<%# 탭 %>
<nav class="flex gap-2 border-b border-slate-200 mb-4">
  <% [["active", "운영 중", @counts[:active]], ["pending", "승인 대기", @counts[:pending]], ["paused", "일시중지", @counts[:paused]]].each do |tab_id, label, n| %>
    <a href="<%= app_automation_rules_v2_path(tab: tab_id) %>"
       class="px-4 py-2 text-sm font-medium <%= @tab == tab_id ? 'border-b-2 border-emerald-600 text-emerald-700' : 'text-slate-500 hover:text-slate-700' %>">
      <%= label %> <span class="text-xs text-slate-400">(<%= n %>)</span>
    </a>
  <% end %>
</nav>

<% if @rules.empty? %>
  <%= render "shared/empty_state",
             icon: "🤖",
             title: "해당 상태의 자동 게시 규칙이 없습니다.",
             body: "소희가 제안한 자동 게시 규칙은 승인 후 운영팀과 협의하여 활성화됩니다." %>
<% else %>
  <div class="space-y-3">
    <% @rules.each do |rule| %>
      <article class="rounded-lg border border-slate-200 bg-white p-4">
        <header class="flex items-start justify-between mb-2">
          <div>
            <h3 class="font-bold text-slate-900">
              <%= link_to rule.name, app_automation_rule_v2_path(rule), class: "hover:underline" %>
            </h3>
            <p class="text-xs text-slate-500 mt-0.5">
              <%= intent_labels[rule.intent_kind] || rule.intent_kind %>
              <% if rule.ai_employee_id %> · AI 직원 ##{rule.ai_employee_id}<% end %>
            </p>
          </div>
          <span class="text-xs px-3 py-1 rounded-full font-medium <%= status_color[rule.status] || 'bg-slate-100 text-slate-500' %>">
            <%= status_label[rule.status] || rule.status %>
          </span>
        </header>

        <p class="text-sm text-slate-700 mb-3"><%= rule.natural_language %></p>

        <% plan = (JSON.parse(rule.structured_plan) rescue {}) %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs">
          <% if plan["cadence"] || plan["weekday"] || plan["time"] %>
            <div>
              <dt class="text-slate-500">주기</dt>
              <dd class="text-slate-700"><%= [plan["cadence"], plan["weekday"], plan["time"]].compact.join(" · ") %></dd>
            </div>
          <% end %>
          <% if plan["channel"] %>
            <div>
              <dt class="text-slate-500">채널</dt>
              <dd class="text-slate-700"><%= plan["channel"] %></dd>
            </div>
          <% end %>
          <% if rule.approved_at %>
            <div>
              <dt class="text-slate-500">승인 일시</dt>
              <dd class="text-slate-700"><%= rule.approved_at.strftime("%Y-%m-%d %H:%M") %></dd>
            </div>
          <% end %>
          <% if rule.automation_schedules.any? %>
            <div>
              <dt class="text-slate-500">다음 실행</dt>
              <dd class="text-slate-700"><%= rule.automation_schedules.first.next_run_at&.strftime("%Y-%m-%d %H:%M") || "예정 없음" %></dd>
            </div>
          <% end %>
        </div>

        <% if rule.status == "draft" %>
          <div class="mt-3 flex gap-2">
            <%= button_to "승인", app_approve_automation_rule_v2_path(rule), method: :post, class: "rounded-md bg-emerald-600 text-white px-4 py-2 text-xs font-medium hover:bg-emerald-700" %>
            <p class="text-xs text-slate-500 self-center">승인 시 즉시 활성화되며 다음 예정 시간부터 실행됩니다.</p>
          </div>
        <% elsif rule.status == "active" %>
          <div class="mt-3">
            <%= button_to "일시중지", app_pause_automation_rule_v2_path(rule), method: :post, class: "rounded-md border border-slate-300 px-4 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" %>
          </div>
        <% elsif rule.status == "paused" %>
          <div class="mt-3">
            <%= button_to "재개", app_resume_automation_rule_v2_path(rule), method: :post, class: "rounded-md border border-slate-300 px-4 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" %>
          </div>
        <% end %>
      </article>
    <% end %>
  </div>
<% end %>