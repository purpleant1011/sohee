<% content_for(:title, "페르소나 미리보기 — #{@employee.name}") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold">🧪 페르소나 미리보기</h1>
  <p class="mt-1 text-sm text-slate-500"><%= @employee.name %> — 샘플 3가지 응답 시뮬레이션</p>
</header>

<div class="space-y-4">
  <% @previews.each_with_index do |preview, idx| %>
    <div class="rounded-md border border-slate-200 bg-white p-5">
      <div class="flex items-start gap-3 mb-3">
        <span class="inline-block rounded-full bg-slate-200 text-slate-700 px-3 py-1 text-xs">손님</span>
        <p class="flex-1 text-sm"><%= preview[:user] %></p>
      </div>
      <div class="flex items-start gap-3 pl-6 border-l-4 border-emerald-300 ml-3">
        <span class="inline-block rounded-full bg-emerald-600 text-white px-3 py-1 text-xs whitespace-nowrap"><%= @employee.name %></span>
        <pre class="flex-1 text-sm text-slate-800 whitespace-pre-wrap font-sans"><%= preview[:response] %></pre>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-6 flex gap-2">
  <%= link_to "← #{@employee.name} 상세", app_ai_employee_path(@employee), class: "inline-flex items-center rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
  <%= link_to "설정 수정", edit_app_ai_employee_path(@employee), class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
</div>